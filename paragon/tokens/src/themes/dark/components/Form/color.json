{
  "color": {
    "form": {
      "control": {
        "indicator": {
          "bg": {
            "base": {
              "$value": "{color.form.input.bg.base}"
            }
          },
          "border": {
            "$value": "#c4c7cf"
          }
        }
      },
      "input": {
        "base": {
          "$value": "{color.body.base}"
        },
        "bg": {
          "base": {
            "$value": "{color.white}"
          }
        },
        "border": {
          "$value": "{color.primary.base}"
        },
        "hover": {
          "border": {
            "$value": "{color.primary.base}"
          }
        },
        "focus": {
          "bg": {
            "$value": "{color.white}"
          },
          "border": {
            "$value": "{color.primary.base}"
          }
        }
      }
    }
  }
}
