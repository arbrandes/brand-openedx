{
  "color": {
    "alert": {
      "bg": {
        "info": {
          "value": "{color.bg.hover}",
          "$type": "color",
          "source": "$alert-info-bg"
        },
        "danger": {
          "value": "#333",
          "$type": "color",
          "source": "$alert-danger-bg"
        }
      },
      "actions": {
        "overrides": {
          "button": {
            "variants": {
              "primary": "brand"
            }
          }
        }
      }
    }
  }
}
