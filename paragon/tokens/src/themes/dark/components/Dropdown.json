{
  "color": {
    "dropdown": {
      "border": {
        "$value": "{color.text.base}"
      },
      "bg": {
        "$value": "{color.body.bg}"
      },
      "link": {
        "base": {
          "$value": "{color.body.base}"
        },
        "active": {
          "base": {
            "$value": "{color.text.base}"
          },
          "bg": {
            "$value": "{color.primary.base}"
          }
        },
        "hover": {
          "base": {
            "$value": "{color.body.bg}"
          },
          "bg": {
            "$value": "{color.body.base}"
          }
        }
      }
    },
    "menu": {
      "item": {
        "bg": {
          "$value": "{color.body.bg}"
        },
        "hover": {
          "bg": {
            "$value": "{color.primary.light}"
          }
        },
        "focus": {
          "bg": {
            "$value": "{color.primary.light}"
          },
          "color": {
            "$value": "{color.body.bg}"
          }
        }
      }
    }
  }
}
