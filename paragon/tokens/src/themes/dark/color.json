    "success": {
      "500": {
        "source": "$success-500",
        "actions": {
          "default": "{color.success.500}"
        },
        "$value": "#3a8e41",
        "$description": "Success color of level 500."
      },
      "base": {
        "$value": "#54CF5E",
        "source": "$success",
        "actions": {
          "default": "{color.success.base}"
        },
        "$description": "Basic success color, dark theme."
      }
    },
    "danger": {
      "base": {
        "$value": "#FFA07A",
        "source": "$danger",
        "actions": {
          "default": "{color.danger.base}"
        },
        "$description": "Basic danger color, dark theme."
      }
