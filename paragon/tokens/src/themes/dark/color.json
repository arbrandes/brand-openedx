    "white": {
      "$value": "{color.body.bg}",
      "source": "$light-100",
      "actions": {
        "default": "{color.body.bg}"
      },
      "$description": "Header background color Profile page."
    },
    "toast": {
      "bg": {
        "$value": "{color.primary.light}"
      },
      "border": {
        "$value": "{color.text.base}"
      }
    }
  }
}
