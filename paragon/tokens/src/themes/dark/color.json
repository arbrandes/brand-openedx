{
  "$type": "color",
  "color": {
    "light": {
      "base": {
        "$value": "#DDDFE2",
        "source": "$primary",
        "actions": {
          "default": "{color.light.base}"
        },
        "$description": "Basic light color, dark theme."
      }
    },
    "primary": {
      "100": {
        "source": "$primary-100",
        "actions": {
          "default": "{color.primary.100}"
        },
        "$value": "#8e9fbf",
        "$description": "Primary color of level 100."
      },
      "500": {
        "source": "$primary-500",
        "actions": {
          "default": "{color.primary.500}"
        },
        "$value": "#747e92",
        "$description": "Primary color of level 500."
      },
      "base": {
        "$value": "#AEC7F6",
        "source": "$primary",
        "actions": {
          "default": "{color.primary.base}"
        },
        "$description": "Basic primary color, dark theme."
      },
      "700": {
        "source": "$primary-700",
        "actions": {
          "default": "{color.primary.700}"
        },
        "$value": "#5a6278",
        "$description": "Primary color of level 700."
      },
      "light": {
        "$value": "#292A2C",
        "source": "$primary-light",
        "actions": {
          "default": "{color.primary.light}"
        },
        "$description": "Light primary color, dark theme."
      },
      "border": {
        "$value": "#777792",
        "source": "$primary-border",
        "actions": {
          "default": "{color.primary.border}"
        },
        "$description": "Primary border color, dark theme."
